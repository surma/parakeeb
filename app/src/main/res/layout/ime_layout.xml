<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F0F0"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <FrameLayout
            android:id="@+id/ime_rewrite"
            android:layout_width="48dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_backspace"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/ime_rewrite">

            <ImageView
                android:id="@+id/ime_rewrite_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_rewrite"
                android:scaleType="centerInside"
                android:tint="#333333" />

            <ProgressBar
                android:id="@+id/ime_rewrite_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp">

            <ImageView
                android:id="@+id/ime_space"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_space"
                android:scaleType="centerInside"
                android:background="@drawable/bg_backspace"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="4dp"
                android:contentDescription="Space"/>

            <ImageView
                android:id="@+id/ime_record"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@android:drawable/ic_btn_speak_now"
                android:scaleType="centerInside"
                android:background="@drawable/bg_record_progress"
                android:clickable="true"
                android:focusable="true"
                android:tint="@color/colorPrimary"
                android:contentDescription="Record"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ime_enter"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_enter"
            android:scaleType="centerInside"
            android:background="@drawable/bg_backspace"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Enter"/>

        <TextView
            android:id="@+id/ime_backspace"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:text="⌫"
            android:textSize="24sp"
            android:textColor="#333333"
            android:background="@drawable/bg_backspace"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Backspace"/>
    </LinearLayout>

</LinearLayout>
